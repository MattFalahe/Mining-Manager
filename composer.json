{
    "name": "mattfalahe/seat-corp-mining-manager",
    "description": "Advanced mining management system for SeAT with analytics, events, and tax management",
    "type": "seat-plugin",
    "license": "GPL-2.0",
    "authors": [
        {
            "name": "Matt Falahe",
            "email": "mattfalahe@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
